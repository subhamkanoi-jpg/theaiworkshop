# Copy this file to `.env` for local dev, and set the same keys in
# Vercel → Project → Settings → Environment Variables for production.

# ── Razorpay ────────────────────────────────────────────────
# TEST keys (rzp_test_...) for testing — no real money moves.
# Swap to LIVE keys (rzp_live_...) only when you're ready to take real payments.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail SMTP) ──────────────────────────────────────
# SMTP_APP_PASSWORD is a Gmail *App Password* (16 chars), NOT your login
# password. Requires 2-Step Verification ON:
#   myaccount.google.com → Security → App passwords
SMTP_EMAIL=theaiworkshop.in@gmail.com
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where new-registration notifications are sent. Defaults to the address below
# if left unset.
ADMIN_EMAIL=theaiworkshop.in@gmail.com

# ── Ad / analytics tracking (optional) ─────────────────────
# Leave any of these blank and that platform is simply skipped — no errors.
# These are PUBLIC (they ship to the browser); the VITE_ prefix is required.
#
# Meta Pixel ID — Meta Events Manager → Data Sources (for Facebook/Instagram ads)
VITE_META_PIXEL_ID=
# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX)
VITE_GA_ID=
# Google Ads conversion ID (looks like AW-XXXXXXXXXX) + the conversion "label"
VITE_GOOGLE_ADS_ID=
VITE_GOOGLE_ADS_PURCHASE_LABEL=
